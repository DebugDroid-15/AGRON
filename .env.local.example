# Supabase Configuration
# Get these values from: https://supabase.com/dashboard/project/_/settings/api

# Your project URL (example: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co

# Your anonymous key (starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Your service role key (for server-side operations)
# Get from: Settings → API → Service Role Key
NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY=eyJ...
